<Window x:Class="LUnivers_Beaute.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LUnivers_Beaute.Views"
        Title="L'Univers Beauté — Hệ Thống Quản Lý" 
        Icon="LUniverBeauteLogo.ico"
        Height="800" Width="1400"
        MinHeight="700" MinWidth="1200"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Normal"
        ResizeMode="CanResize"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0" ResizeBorderThickness="7" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="16" Background="{StaticResource SurfaceBgBrush}" 
            BorderBrush="#F3D1BC" BorderThickness="1" x:Name="MainBorder">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FLOATING SIDEBAR -->
            <Border Grid.Column="0" CornerRadius="16" Background="#FFFFFFFF" Margin="16,16,8,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="42" Height="42" CornerRadius="21" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8956D" Offset="0"/>
                                        <GradientStop Color="#D4A574" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="✦" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="Bold" Foreground="#2D2D2D" FontFamily="Georgia">
                                    <Run Text="L' Universe"/>
                                </TextBlock>
                                <TextBlock Text="Beauté" FontSize="12" Foreground="#E8956D" FontFamily="Georgia" FontStyle="Italic" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#F0F0F0" Margin="0,20,0,0"/>
                    </StackPanel>

                    <!-- NAV MENU -->
                    <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,10">

                            <RadioButton x:Name="navDashboard" Style="{StaticResource NavButton}" IsChecked="True" Checked="Nav_Checked" Tag="Dashboard" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tổng quan" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── BÁN HÀNG ── -->
                            <TextBlock x:Name="grpBanHangHeader" Text="BÁN HÀNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton x:Name="navBanHang" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="BanHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Bán hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navHoaDon" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="HoaDon" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧾" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hóa đơn" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navTraHang" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="TraHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↩️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Trả hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navKhuyenMai" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhuyenMai" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎁" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Khuyến mãi" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── SẢN PHẨM ── -->
                            <TextBlock x:Name="grpSanPhamHeader" Text="SẢN PHẨM" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton x:Name="navSanPham" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="SanPham" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💄" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sản phẩm" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navDanhMuc" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="DanhMuc" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Danh mục" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navThuongHieu" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="ThuongHieu" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏷️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thương hiệu" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navNhaCungCap" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhaCungCap" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏭" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhà cung cấp" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── KHO HÀNG ── -->
                            <TextBlock x:Name="grpKhoHangHeader" Text="KHO HÀNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton x:Name="navKhoHang" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhoHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tồn kho" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navNhapKho" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhapKho" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhập kho" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navKiemKe" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KiemKe" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Kiểm kê" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navHuySanPham" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="HuySanPham" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hủy sản phẩm" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── HỆ THỐNG ── -->
                            <TextBlock x:Name="grpHeThongHeader" Text="HỆ THỐNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton x:Name="navKhachHang" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhachHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Khách hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navNhanVien" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhanVien" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhân viên" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navChamCong" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="ChamCong" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏰" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Chấm công" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navCuaHang" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="CuaHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏪" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cửa hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navLichSuTruyCap" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="LichSuTruyCap" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Lịch sử truy cập" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="navLichSuChinhSua" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="LichSuChinhSua" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Lịch sử chỉnh sửa" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- BOTTOM ACTIONS -->
                    <StackPanel Grid.Row="2" Margin="10,0,10,12">
                        <Border Height="1" Background="#F0F0F0" Margin="6,0,6,8"/>
                        <RadioButton x:Name="navCaiDat" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="CaiDat" GroupName="MainNav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Cài đặt" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </RadioButton>
                        <Button Click="BtnLogout_Click" Height="42" Margin="10,1" Cursor="Hand" BorderThickness="0" Background="Transparent" HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="14,0">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FFF0F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#E74C3C"/>
                                <TextBlock Text="Đăng xuất" FontSize="13" VerticalAlignment="Center" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT SECTION -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FLOATING TOP BAR -->
                <Border Grid.Row="0" Margin="8,16,16,8" Padding="24,12" Background="#FFFFFFFF" CornerRadius="16"
                        MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.06" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Box with Suggestion Popup -->
                        <Grid x:Name="searchContainer" Grid.Column="0">
                            <Border x:Name="searchBorder" Background="#F8F9FA" CornerRadius="12" Padding="16,0" Width="550" HorizontalAlignment="Left">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.5"/>
                                    <TextBox x:Name="searchBox" Grid.Column="1" Background="Transparent" BorderThickness="0"
                                             Foreground="#2D2D2D" FontSize="14" VerticalAlignment="Center" Padding="0,12"
                                             FontFamily="Segoe UI" CaretBrush="{StaticResource AccentPeachBrush}"
                                             TextChanged="SearchBox_TextChanged" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                                    <TextBlock Text="Tìm nhanh chức năng... (Bán hàng, Sản phẩm, Lịch sử...)" Foreground="#B0B0B0" FontSize="13.5" VerticalAlignment="Center" Grid.Column="1" IsHitTestVisible="False" Margin="2,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=searchBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Popup x:Name="popupSearch" PlacementTarget="{Binding ElementName=searchBorder}" Placement="Bottom" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade">
                                <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E5E7EB" Width="550" Margin="0,4,0,16" Padding="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="CHỨC NĂNG HỆ THỐNG GỢI Ý" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF" Margin="12,6,12,6"/>
                                        <ListBox x:Name="lstSearchResults" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 SelectionChanged="LstSearchResults_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="12,10"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="#F3E8FF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        <TextBlock x:Name="txtNoResults" Text="Không tìm thấy chức năng tương ứng..." FontSize="13" Foreground="#9CA3AF" Margin="12,10" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Right Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <!-- Notification Bell & Badge with Popup -->
                            <Grid>
                                <Button x:Name="btnBell" Style="{StaticResource IconButton}" Content="🔔" FontSize="18" Margin="4,0" Width="40" Height="40" Click="BtnBell_Click"/>
                                <!-- Red notification dot badge -->
                                <Border x:Name="badgeNotification" Background="#EF4444" Width="8" Height="8" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                                
                                <Popup x:Name="popupNotifications" PlacementTarget="{Binding ElementName=btnBell}" Placement="Bottom" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Slide" HorizontalOffset="-310">
                                    <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E5E7EB" Width="350" Margin="0,4,0,16" Padding="16">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Title Bar -->
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <TextBlock Text="Thông báo hoạt động mới" FontSize="14" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                                <Button Content="Đánh dấu đã đọc" Background="Transparent" BorderThickness="0" Foreground="#6D28D9" FontSize="11" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Right" Click="BtnMarkRead_Click" VerticalAlignment="Center"/>
                                            </Grid>
                                            
                                            <Border Grid.Row="1" Height="1" Background="#F3F4F6" Margin="0,0,0,10"/>
                                            
                                            <!-- Notification list content -->
                                            <ScrollViewer Grid.Row="2" MaxHeight="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel x:Name="pnlNotificationsList">
                                                    <!-- Loaded dynamically -->
                                                </StackPanel>
                                            </ScrollViewer>
                                            
                                            <Border Grid.Row="3" Height="1" Background="#F3F4F6" Margin="0,10,0,10"/>
                                            
                                            <!-- Footer Button -->
                                            <Button Grid.Row="3" Content="Xem tất cả lịch sử chỉnh sửa" Background="Transparent" BorderThickness="0" Foreground="#6D28D9" FontSize="12.5" FontWeight="SemiBold" Cursor="Hand" Click="BtnViewAllLogs_Click" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button Style="{StaticResource IconButton}" Content="🛒" FontSize="18" Margin="4,0" Width="40" Height="40"/>
                            <Border Width="1" Height="24" Background="#E0E0E0" Margin="12,0"/>

                            <!-- User Profile -->
                            <StackPanel Orientation="Horizontal" Margin="4,0" Cursor="Hand">
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8956D" Offset="0"/>
                                            <GradientStop Color="#D4A574" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="txtUserAvatar" Text="LH" FontSize="14" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="#E8956D"/>
                                    </Border.Effect>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock x:Name="txtUserName" Text="Linh Hoa" FontSize="14" FontWeight="Bold" Foreground="#2D2D2D"/>
                                    <TextBlock x:Name="txtUserRole" Text="Quản lý trưởng" FontSize="11" Foreground="{StaticResource AccentPeachBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Window Controls -->
                            <Border Width="1" Height="24" Background="#E0E0E0" Margin="8,0,16,0"/>
                            <Button Style="{StaticResource IconButton}" Content="─" FontSize="12" Click="BtnMinimize_Click" Margin="2,0" Width="36" Height="36"/>
                            <Button Style="{StaticResource IconButton}" Content="□" FontSize="15" Click="BtnMaximize_Click" Margin="2,0" Width="36" Height="36"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CONTENT HOST -->
                <ContentControl Grid.Row="1" x:Name="ContentArea" Margin="0,0,16,16"/>
            </Grid>

            <!-- FLOATING CHATBOT WIDGET -->
            <Grid Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,32,32" Panel.ZIndex="100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="pnlChatbot" Grid.Row="0" Width="420" Height="650" Margin="0,0,0,16" 
                        Background="White" CornerRadius="16" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Direction="270" Color="Black"/>
                    </Border.Effect>
                    <views:ChatbotView />
                </Border>
                
                <Button x:Name="btnToggleChatbot" Grid.Row="1" Width="60" Height="60" HorizontalAlignment="Right" 
                        Click="BtnToggleChatbot_Click" Cursor="Hand" Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="30">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8956D" Offset="0"/>
                                        <GradientStop Color="#D4764E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.3" Color="#D4764E"/>
                                </Border.Effect>
                                <TextBlock Text="✨" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Margin="0,0,0,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05" CenterX="30" CenterY="30"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
