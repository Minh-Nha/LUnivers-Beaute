<Window x:Class="LUnivers_Beaute.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LUnivers_Beaute.Views"
        Title="L'Univers Beauté — Hệ Thống Quản Lý" 
        Height="800" Width="1400"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border CornerRadius="16" Background="{StaticResource SurfaceBgBrush}" 
            BorderBrush="#F3D1BC" BorderThickness="1" x:Name="MainBorder">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FLOATING SIDEBAR -->
            <Border Grid.Column="0" CornerRadius="16" Background="#FFFFFFFF" Margin="16,16,8,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="42" Height="42" CornerRadius="21" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8956D" Offset="0"/>
                                        <GradientStop Color="#D4A574" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="✦" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="Bold" Foreground="#2D2D2D" FontFamily="Segoe UI">
                                    <Run Text="L' Universe"/>
                                </TextBlock>
                                <TextBlock Text="Beauté" FontSize="12" Foreground="#E8956D" FontFamily="Segoe UI" FontStyle="Italic" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#F0F0F0" Margin="0,20,0,0"/>
                    </StackPanel>

                    <!-- NAV MENU -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,10">

                            <RadioButton x:Name="navDashboard" Style="{StaticResource NavButton}" IsChecked="True" Checked="Nav_Checked" Tag="Dashboard" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tổng quan" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── BÁN HÀNG ── -->
                            <TextBlock Text="BÁN HÀNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="BanHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Bán hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="HoaDon" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧾" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hóa đơn" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhuyenMai" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎁" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Khuyến mãi" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── SẢN PHẨM ── -->
                            <TextBlock Text="SẢN PHẨM" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="SanPham" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💄" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sản phẩm" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="DanhMuc" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Danh mục" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="ThuongHieu" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏷️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thương hiệu" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhaCungCap" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏭" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhà cung cấp" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── KHO HÀNG ── -->
                            <TextBlock Text="KHO HÀNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhoHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tồn kho" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhapKho" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhập kho" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KiemKe" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Kiểm kê" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- ── HỆ THỐNG ── -->
                            <TextBlock Text="HỆ THỐNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="24,14,0,6" FontFamily="Segoe UI"/>

                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="KhachHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Khách hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="NhanVien" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhân viên" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="ChamCong" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏰" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Chấm công" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="CuaHang" GroupName="MainNav">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏪" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cửa hàng" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- BOTTOM ACTIONS -->
                    <StackPanel Grid.Row="2" Margin="10,0,10,12">
                        <Border Height="1" Background="#F0F0F0" Margin="6,0,6,8"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="MainNav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Cài đặt" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </RadioButton>
                        <Button Style="{StaticResource IconButton}" Width="Auto" Height="42" HorizontalAlignment="Stretch" Click="BtnLogout_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="⏻" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#E74C3C"/>
                                <TextBlock Text="Đăng xuất" FontSize="13" VerticalAlignment="Center" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT SECTION -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FLOATING TOP BAR -->
                <Border Grid.Row="0" Margin="8,16,16,8" Padding="24,12" Background="#FFFFFFFF" CornerRadius="16"
                        MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.06" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Box -->
                        <Border Background="#F8F9FA" CornerRadius="12" Padding="16,0" MaxWidth="400" HorizontalAlignment="Left">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.5"/>
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                         Foreground="#2D2D2D" FontSize="14" VerticalAlignment="Center" Padding="0,12"
                                         FontFamily="Segoe UI" CaretBrush="{StaticResource AccentPeachBrush}"/>
                                <TextBlock Text="Tìm kiếm mọi thứ..." Foreground="#B0B0B0" FontSize="14" VerticalAlignment="Center" Grid.Column="1" IsHitTestVisible="False" Margin="2,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=searchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Right Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Notification & Cart -->
                            <Button Style="{StaticResource IconButton}" Content="🔔" FontSize="18" Margin="4,0" Width="40" Height="40"/>
                            <Button Style="{StaticResource IconButton}" Content="🛒" FontSize="18" Margin="4,0" Width="40" Height="40"/>
                            <Border Width="1" Height="24" Background="#E0E0E0" Margin="12,0"/>

                            <!-- User Profile -->
                            <StackPanel Orientation="Horizontal" Margin="4,0" Cursor="Hand">
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8956D" Offset="0"/>
                                            <GradientStop Color="#D4A574" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="LH" FontSize="14" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="#E8956D"/>
                                    </Border.Effect>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="Linh Hoa" FontSize="14" FontWeight="Bold" Foreground="#2D2D2D"/>
                                    <TextBlock Text="Quản lý trưởng" FontSize="11" Foreground="{StaticResource AccentPeachBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Window Controls -->
                            <Border Width="1" Height="24" Background="#E0E0E0" Margin="8,0,16,0"/>
                            <Button Style="{StaticResource IconButton}" Content="─" FontSize="12" Click="BtnMinimize_Click" Margin="2,0" Width="36" Height="36"/>
                            <Button Style="{StaticResource IconButton}" Content="□" FontSize="15" Click="BtnMaximize_Click" Margin="2,0" Width="36" Height="36"/>
                            <Button Content="✕" FontSize="12" Click="BtnClose_Click" Width="36" Height="36">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CONTENT HOST -->
                <ContentControl Grid.Row="1" x:Name="ContentArea" Margin="0,0,16,16"/>
            </Grid>
        </Grid>
    </Border>
</Window>
