<UserControl x:Class="LUnivers_Beaute.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: PRODUCT CATALOG -->
        <Grid Grid.Column="0" Margin="24,20,12,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Row -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Bán hàng" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Chọn sản phẩm để thêm vào giỏ hàng" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Store selector top-right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="🏪" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cboCuaHang" Style="{StaticResource ModernComboBox}" Width="180" SelectionChanged="CboCuaHang_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TenCuaHang}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Search + Category Filter -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="10" Padding="14,0" BorderBrush="#E8E8E8" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.4"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1" TextChanged="TxtSearch_TextChanged" Background="Transparent" BorderThickness="0" Foreground="#2D2D2D" FontSize="13" VerticalAlignment="Center" Padding="0,11" CaretBrush="#E8956D"/>
                        <TextBlock Text="Tìm sản phẩm..." Foreground="#C0C0C0" VerticalAlignment="Center" Grid.Column="1" IsHitTestVisible="False" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <ComboBox x:Name="cboDanhMuc" SelectionChanged="CboDanhMuc_SelectionChanged" Grid.Column="1" Style="{StaticResource ModernComboBox}" Margin="10,0,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TenDanhMuc}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <!-- Product Grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icProducts">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="145" Margin="0,0,10,12" CornerRadius="14" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" MouseLeftButtonUp="Product_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#E8956D"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#E8956D" ShadowDepth="0" BlurRadius="12" Opacity="0.15"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <StackPanel Margin="10">
                                        <Grid Height="110" Margin="0,0,0,10">
                                            <Border CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FFF0E6" Offset="0"/>
                                                        <GradientStop Color="#FFE0CC" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="💄" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <Border CornerRadius="10">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding HinhAnh}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding TenSanPham}" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis" Height="18"/>
                                        <TextBlock Text="{Binding TenThuongHieu}" FontSize="10" Foreground="#B0B0B0" Margin="0,2,0,8" TextTrimming="CharacterEllipsis"/>
                                        
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding GiaNiemYet, StringFormat={}{0:N0} ₫}" FontSize="14" FontWeight="Bold" Foreground="#E8956D" Margin="0,0,0,4"/>
                                            <Border Background="#E8F5E9" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#2E7D32">
                                                    <Run Text="SL: "/><Run Text="{Binding SoLuongTon, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button x:Name="btnPrevPage" Content="&lt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnPrevPage_Click"/>
                <TextBlock x:Name="txtPageInfo" Text="Trang 1 / 1" VerticalAlignment="Center" Margin="16,0" FontWeight="SemiBold" Foreground="#2D2D2D"/>
                <Button x:Name="btnNextPage" Content="&gt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnNextPage_Click"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT: CART PANEL -->
        <Border Grid.Column="1" Background="White" CornerRadius="16,0,0,16" Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="180" ShadowDepth="0" BlurRadius="20" Opacity="0.06"/>
            </Border.Effect>
            <Grid Margin="20,20,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart Header -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛒" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Giỏ hàng" FontSize="17" FontWeight="Bold" Foreground="#2D2D2D" VerticalAlignment="Center"/>
                        <Border x:Name="badgeCount" Background="#E8956D" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtCartCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <Button Content="Xóa tất cả" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="12,6" FontSize="11" Click="BtnXoaTatCa_Click"/>
                </Grid>

                <!-- Customer Selection -->
                <Border Grid.Row="1" CornerRadius="10" Background="#FAFAFA" Padding="12" Margin="0,0,0,10" BorderBrush="#F0F0F0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,0">
                            <TextBlock Text="TÌM KHÁCH HÀNG (SĐT)" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📞" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.5"/>
                                    <TextBox x:Name="txtSoDienThoai" Grid.Column="1" MaxLength="10" Padding="8,8" FontSize="13" TextChanged="TxtSoDienThoai_TextChanged" PreviewTextInput="NumberOnly_PreviewTextInput" Background="Transparent" BorderThickness="0" Foreground="#2D2D2D" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="2" Content="✕" Style="{StaticResource IconButton}" Width="24" Height="24" FontSize="10" Margin="0,0,6,0" Click="BtnClearKhachHang_Click" ToolTip="Xóa SĐT" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="txtTenKhachHang" Text="Khách vãng lai" FontSize="12" FontWeight="SemiBold" Foreground="#4CAF50" Margin="0,4,0,0" Visibility="Visible"/>
                        </StackPanel>
                    </Grid>
                </Border>



                <!-- Cart Items List -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <ItemsControl x:Name="icCart">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Background="#FAFAFA" Padding="12" Margin="0,0,0,8" BorderBrush="#F0F0F0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TenSanPham}" FontSize="13" FontWeight="SemiBold" Foreground="#2D2D2D" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="38"/>
                                            <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} ₫}" FontSize="12" Foreground="#E8956D" Margin="0,3,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="6" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="−" Width="30" Height="28" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" Foreground="#888" Cursor="Hand" Click="BtnGiam_Click" Tag="{Binding MaSanPham}"/>
                                                        <TextBlock Text="{Binding SoLuong}" FontSize="13" Margin="4,0" VerticalAlignment="Center" Foreground="#2D2D2D" FontWeight="Bold" MinWidth="20" TextAlignment="Center"/>
                                                        <Button Content="+" Width="30" Height="28" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" Foreground="#E8956D" Cursor="Hand" Click="BtnTang_Click" Tag="{Binding MaSanPham}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <Button Content="✕" Style="{StaticResource IconButton}" Width="24" Height="24" FontSize="10" Click="BtnXoa_Click" Tag="{Binding MaSanPham}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding ThanhTien, StringFormat={}{0:N0} ₫}" FontSize="14" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,12,0,0" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Payment and Promotion -->
                <Grid Grid.Row="4" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="THANH TOÁN" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cboThanhToan" Style="{StaticResource ModernComboBox}" SelectionChanged="CboThanhToan_SelectionChanged">
                            <ComboBoxItem Content="Tiền mặt" IsSelected="True"/>
                            <ComboBoxItem Content="Chuyển khoản"/>
                            <ComboBoxItem Content="Thẻ tín dụng"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="KHUYẾN MÃI" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cboKhuyenMai" Style="{StaticResource ModernComboBox}" SelectedValuePath="MaKhuyenMai" SelectionChanged="CboKhuyenMai_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TenChuongTrinh}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Price Summary -->
                <Border Grid.Row="5" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FAFAFA" Offset="0"/>
                            <GradientStop Color="#F5F5F5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Tạm tính:" Foreground="#7A7A7A" FontSize="13"/>
                            <TextBlock x:Name="txtTamTinh" Text="0 ₫" HorizontalAlignment="Right" Foreground="#2D2D2D" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Khuyến mãi:" Foreground="#7A7A7A" FontSize="13"/>
                            <TextBlock x:Name="txtKhuyenMai" Text="-0 ₫" HorizontalAlignment="Right" Foreground="#4CAF50" FontSize="13" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Điểm tích lũy KH:" Foreground="#7A7A7A" FontSize="12"/>
                            <TextBlock x:Name="txtDiemTichLuy" Text="⭐ 0" HorizontalAlignment="Right" Foreground="#F5A623" FontSize="12" FontWeight="SemiBold"/>
                        </Grid>
                        <Border Height="1" Background="#E0E0E0" Margin="0,4,0,10"/>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="KHÁCH CẦN TRẢ:" Foreground="#2D2D2D" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTongCong" Text="0 ₫" HorizontalAlignment="Right" Foreground="#E8956D" FontSize="20" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Tiền khách đưa:" Foreground="#7A7A7A" FontSize="13" VerticalAlignment="Center"/>
                            <Border BorderBrush="#E8956D" BorderThickness="1.5" CornerRadius="8" HorizontalAlignment="Right" Width="170" Background="White">
                                <Grid>
                                    <TextBox x:Name="txtTienKhachDua" TextChanged="TxtTienKhachDua_TextChanged" PreviewTextInput="NumberOnly_PreviewTextInput" TextAlignment="Right" Padding="8,6,28,6" FontSize="14" FontWeight="Bold" Background="Transparent" BorderThickness="0" Foreground="#2D2D2D" CaretBrush="#E8956D"/>
                                    <TextBlock Text="₫" Foreground="#A0A0A0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Tiền thối:" Foreground="#7A7A7A" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTienThoi" Text="0 ₫" HorizontalAlignment="Right" Foreground="#2E7D32" FontSize="16" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Checkout Button -->
                <Button Grid.Row="6" x:Name="btnThanhToan" Height="50" FontSize="15" FontWeight="Bold" Click="BtnThanhToan_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="12" Padding="0,12">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#E8956D" Offset="0"/>
                                                    <GradientStop Color="#D4764E" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="💰 THANH TOÁN" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#D4764E" Offset="0"/>
                                                            <GradientStop Color="#C06540" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
