<UserControl x:Class="LUnivers_Beaute.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="370"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: PRODUCT GRID -->
        <Grid Grid.Column="0" Margin="28,24,12,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Bán hàng" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Chọn sản phẩm để thêm vào giỏ hàng" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="#F8F8F8" CornerRadius="8" Padding="12,0" BorderBrush="#EDEDED" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.4"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="#2D2D2D" FontSize="13" VerticalAlignment="Center" Padding="0,10" CaretBrush="#E8956D"/>
                    </Grid>
                </Border>
                <ComboBox Grid.Column="1" Style="{StaticResource ModernComboBox}" Margin="10,0,0,0" Width="150">
                    <ComboBoxItem Content="Tất cả danh mục" IsSelected="True"/>
                    <ComboBoxItem Content="Son môi"/>
                    <ComboBoxItem Content="Kem dưỡng"/>
                    <ComboBoxItem Content="Nước hoa"/>
                </ComboBox>
                <Button Grid.Column="2" Content="📷 Quét mã" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Padding="14,10"/>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <WrapPanel>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#FFF0E6" Margin="0,0,0,10">
                                <TextBlock Text="💄" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Son MAC Ruby Woo" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="MAC" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="350,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 42" FontSize="10" HorizontalAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#E3F2FD" Margin="0,0,0,10">
                                <TextBlock Text="🧴" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Kem chống nắng Anessa" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Anessa" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="580,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 28" FontSize="10" HorizontalAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#E8F5E9" Margin="0,0,0,10">
                                <TextBlock Text="🧼" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Sữa rửa mặt Cerave" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Cerave" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="290,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 55" FontSize="10" HorizontalAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#F3E5F5" Margin="0,0,0,10">
                                <TextBlock Text="✨" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Nước hoa Chanel No.5" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Chanel" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="2,500,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 12" FontSize="10" HorizontalAlignment="Right" Foreground="#F5A623" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#FFF3E0" Margin="0,0,0,10">
                                <TextBlock Text="💧" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Serum Vitamin C Obagi" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Obagi" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="1,200,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 20" FontSize="10" HorizontalAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Width="175" Margin="0,0,10,10" CornerRadius="12" Cursor="Hand" Background="White" BorderBrush="#EDEDED" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <Border Height="90" CornerRadius="8" Background="#FCE4EC" Margin="0,0,0,10">
                                <TextBlock Text="👁️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Mascara Maybelline" FontSize="12" FontWeight="SemiBold" Foreground="#2D2D2D" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Maybelline" FontSize="11" Foreground="#B0B0B0" Margin="0,2,0,6"/>
                            <Grid>
                                <TextBlock Text="180,000 ₫" FontSize="14" FontWeight="Bold" Foreground="#E8956D"/>
                                <TextBlock Text="SL: 65" FontSize="10" HorizontalAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT: CART PANEL -->
        <Border Grid.Column="1" Background="White" BorderBrush="#EDEDED" BorderThickness="1,0,0,0">
            <Grid Margin="18,24,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="🛒 Giỏ hàng" FontSize="16" FontWeight="Bold" Foreground="#2D2D2D"/>
                    <Button Content="Xóa tất cả" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="10,5" FontSize="11"/>
                </Grid>

                <Border Grid.Row="1" CornerRadius="10" Background="#F8F8F8" Padding="12" Margin="0,0,0,12" BorderBrush="#EDEDED" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="KHÁCH HÀNG" FontSize="10" FontWeight="Bold" Foreground="#B0B0B0" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}" FontSize="12" Padding="10,7"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="+" Style="{StaticResource PrimaryButton}" Width="34" Height="34" Padding="0" FontSize="16" Margin="8,16,0,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel>
                        <Border CornerRadius="10" Background="#FAFAFA" Padding="12" Margin="0,0,0,8" BorderBrush="#F0F0F0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Son MAC Ruby Woo" FontSize="13" FontWeight="SemiBold" Foreground="#2D2D2D"/>
                                    <TextBlock Text="350,000 ₫" FontSize="12" Foreground="#E8956D" Margin="0,2,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="−" Style="{StaticResource SecondaryButton}" Width="26" Height="26" Padding="0" FontSize="13"/>
                                        <TextBlock Text="2" FontSize="13" Margin="10,0" VerticalAlignment="Center" Foreground="#2D2D2D" FontWeight="SemiBold"/>
                                        <Button Content="+" Style="{StaticResource SecondaryButton}" Width="26" Height="26" Padding="0" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <Button Content="✕" Style="{StaticResource IconButton}" Width="22" Height="22" FontSize="9"/>
                                    <TextBlock Text="700,000 ₫" FontSize="13" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border CornerRadius="10" Background="#FAFAFA" Padding="12" Margin="0,0,0,8" BorderBrush="#F0F0F0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Kem chống nắng Anessa" FontSize="13" FontWeight="SemiBold" Foreground="#2D2D2D"/>
                                    <TextBlock Text="580,000 ₫" FontSize="12" Foreground="#E8956D" Margin="0,2,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="−" Style="{StaticResource SecondaryButton}" Width="26" Height="26" Padding="0" FontSize="13"/>
                                        <TextBlock Text="1" FontSize="13" Margin="10,0" VerticalAlignment="Center" Foreground="#2D2D2D" FontWeight="SemiBold"/>
                                        <Button Content="+" Style="{StaticResource SecondaryButton}" Width="26" Height="26" Padding="0" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <Button Content="✕" Style="{StaticResource IconButton}" Width="22" Height="22" FontSize="9"/>
                                    <TextBlock Text="580,000 ₫" FontSize="13" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" CornerRadius="10" Background="#FAFAFA" Padding="14" Margin="0,0,0,10" BorderBrush="#F0F0F0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Tạm tính:" Foreground="#7A7A7A" FontSize="13"/>
                            <TextBlock Text="1,280,000 ₫" HorizontalAlignment="Right" Foreground="#2D2D2D" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Khuyến mãi:" Foreground="#7A7A7A" FontSize="13"/>
                            <TextBlock Text="-0 ₫" HorizontalAlignment="Right" Foreground="#4CAF50" FontSize="13"/>
                        </Grid>
                        <Border Height="1" Background="#EDEDED" Margin="0,4,0,8"/>
                        <Grid>
                            <TextBlock Text="Tổng cộng:" Foreground="#2D2D2D" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="1,280,000 ₫" HorizontalAlignment="Right" Foreground="#E8956D" FontSize="17" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Grid.Row="4" Content="💰 THANH TOÁN" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>






