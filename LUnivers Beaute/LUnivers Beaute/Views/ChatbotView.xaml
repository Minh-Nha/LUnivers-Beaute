<UserControl x:Class="LUnivers_Beaute.Views.ChatbotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Elegant Header -->
        <Border Grid.Row="0" Background="Transparent" BorderBrush="#EAEAEA" BorderThickness="0,0,0,1" Padding="0,0,0,20" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="✦" FontSize="36" Foreground="#DE8A63" Margin="0,0,12,0" VerticalAlignment="Center" FontFamily="Georgia"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Cố Vấn Thông Minh" FontSize="26" FontWeight="Normal" Foreground="#2D2D2D" FontFamily="Georgia"/>
                    <TextBlock Text="Sẵn sàng hỗ trợ và phân tích dữ liệu cửa hàng" FontSize="14" Foreground="#888888" Margin="0,4,0,0" FontStyle="Italic" FontFamily="Georgia"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="1" CornerRadius="12" BorderBrush="#EADACF" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF3EB" Offset="0"/>
                    <GradientStop Color="#FAE4D4" Offset="0.5"/>
                    <GradientStop Color="#F3D1BC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16">
                <StackPanel x:Name="spChatArea" Margin="0,0,0,0"/>
            </ScrollViewer>
        </Border>

        <!-- Elegant Input Area -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="6" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtMessage" Padding="16,12" FontSize="15" 
                         Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="100"
                         VerticalContentAlignment="Center" FontFamily="Segoe UI"
                         PreviewKeyDown="TxtMessage_PreviewKeyDown"/>
                
                <Button Grid.Column="1" Width="44" Height="44" Click="BtnSend_Click" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#DE8A63" Offset="0"/>
                                        <GradientStop Color="#C6936A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C6936A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="✦" FontSize="24" Foreground="White" Margin="0,0,0,0" FontFamily="Georgia"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
