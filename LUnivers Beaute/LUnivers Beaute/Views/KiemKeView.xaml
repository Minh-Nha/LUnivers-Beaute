<UserControl x:Class="LUnivers_Beaute.Views.KiemKeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Page Header -->
        <Grid Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Kiểm kê kho" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="So sánh số lượng hệ thống và thực tế để phát hiện chênh lệch" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Content="＋ Tạo phiếu kiểm kê" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnOpenCreate_Click"/>
        </Grid>
        
        <!-- Stat Cards -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#E8F5E9" Margin="0,0,0,10" HorizontalAlignment="Left">
                        <TextBlock Text="✅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Khớp kho" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtKhop" Text="0" FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="4,0,4,0">
                <StackPanel>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#FFF3E0" Margin="0,0,0,10" HorizontalAlignment="Left">
                        <TextBlock Text="📈" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Thừa kho" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtThua" Text="0" FontSize="20" FontWeight="Bold" Foreground="#F5A623"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#FFEBEE" Margin="0,0,0,10" HorizontalAlignment="Left">
                        <TextBlock Text="📉" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Thiếu kho" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtThieu" Text="0" FontSize="20" FontWeight="Bold" Foreground="#E74C3C"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        
        <!-- Filter Bar -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="12,0" Margin="0,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" VerticalAlignment="Center" Foreground="#7A7A7A" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Margin="0,6"/>
                        <TextBlock Text="Tìm kiếm sản phẩm, cửa hàng..." Foreground="#B0B0B0" VerticalAlignment="Center" Grid.Column="1" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                
                <ComboBox x:Name="cmbTinhTrang" Grid.Column="1" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                    <ComboBoxItem Content="Tất cả tình trạng" IsSelected="True"/>
                    <ComboBoxItem Content="Khớp"/>
                    <ComboBoxItem Content="Thừa"/>
                    <ComboBoxItem Content="Thiếu"/>
                </ComboBox>
                
                <Button x:Name="btnSearch" Grid.Column="2" Content="🔍 Tìm kiếm" Style="{StaticResource PrimaryButton}" Padding="24,10" Click="BtnSearch_Click"/>
            </Grid>
        </Border>
        
        <!-- Data Grid -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid AutoGenerateColumns="False" x:Name="dgData" Style="{StaticResource ModernDataGrid}" 
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}" CellStyle="{StaticResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ" Binding="{Binding MaKiemKe}" Width="60"/>
                        <DataGridTextColumn Header="CỬA HÀNG" Binding="{Binding TenCuaHang}" Width="140"/>
                        <DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding TenSanPham}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SỐ LÔ" Binding="{Binding SoLo}" Width="80"/>
                        <DataGridTextColumn Header="SL HỆ THỐNG" Binding="{Binding SoLuongHeThong}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SL THỰC TẾ" Binding="{Binding SoLuongThucTe}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="CHÊNH LỆCH" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SoLuongLech}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TinhTrang}" Value="Thiếu">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TinhTrang}" Value="Thừa">
                                                        <Setter Property="Foreground" Value="#F5A623"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="TÌNH TRẠNG" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TinhTrang}" Value="Thiếu">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TinhTrang}" Value="Thừa">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding TinhTrang}" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TinhTrang}" Value="Thiếu">
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TinhTrang}" Value="Thừa">
                                                            <Setter Property="Foreground" Value="#EF6C00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="NGÀY KIỂM" Binding="{Binding NgayKiem}" Width="130"/>
                        <DataGridTemplateColumn Header="" Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Style="{StaticResource IconButton}" Foreground="Red" Click="BtnDelete_Click" VerticalAlignment="Center" ToolTip="Xóa"
                                            Visibility="{Binding DeleteButtonVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,12">
                    <Button x:Name="btnPrevPage" Content="&lt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnPrevPage_Click"/>
                    <TextBlock x:Name="txtPageInfo" Text="Trang 1 / 1" VerticalAlignment="Center" Margin="16,0" FontWeight="SemiBold"/>
                    <Button x:Name="btnNextPage" Content="&gt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnNextPage_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- OVERLAY: Tạo Phiếu Kiểm Kê -->
        <Grid x:Name="createPanel" Visibility="Collapsed" Grid.RowSpan="4">
            <Border Background="#88000000"/>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="650" 
                    Style="{StaticResource CardBorder}" Padding="28" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="TẠO PHIẾU KIỂM KÊ MỚI" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" Click="BtnCloseCreate_Click"/>
                    </Grid>
                    
                    <!-- Store Selector -->
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cửa hàng:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                            <ComboBox x:Name="cboCuaHangKiemKe" Grid.Column="1" Style="{StaticResource ModernComboBox}" SelectedValuePath="MaCuaHang" SelectionChanged="CboCuaHangKiemKe_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TenCuaHang}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock x:Name="lblItemCount" Grid.Column="2" Text="0 sản phẩm" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <Button Grid.Column="3" Content="Tải lại danh sách" Style="{StaticResource SecondaryButton}" Padding="16,8" Click="BtnReloadStock_Click"/>
                        </Grid>
                    </Border>
                    
                    <!-- Audit Items Table -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,0,0,16" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Table Header -->
                            <Grid Background="#FAFAFA" Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SẢN PHẨM" Grid.Column="0" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                <TextBlock Text="SỐ LÔ" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="HẠN SD" Grid.Column="2" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="SL HỆ THỐNG" Grid.Column="3" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Text="SL THỰC TẾ" Grid.Column="4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                            
                            <!-- Scrollable Items -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="icAuditItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Height="48">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Text="{Binding TenSanPham}" Grid.Column="0" VerticalAlignment="Center" Margin="16,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding SoLo}" Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding HanSuDung}" Grid.Column="2" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding SoLuongHeThong}" Grid.Column="3" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    
                                                    <!-- Editable Actual Quantity -->
                                                    <TextBox Text="{Binding SoLuongThucTe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4" 
                                                             Style="{StaticResource ModernTextBox}" Padding="6,6" FontSize="13" FontWeight="Bold"
                                                             HorizontalContentAlignment="Center" VerticalAlignment="Center" Margin="12,4"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    
                    <!-- Footer -->
                    <Grid Grid.Row="3">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="💡 Nhập số lượng thực tế đếm được vào cột " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="SL THỰC TẾ" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="XÁC NHẬN KIỂM KÊ" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Height="46" FontSize="13" FontWeight="Bold" Padding="24,0" Click="BtnXacNhanKiemKe_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
