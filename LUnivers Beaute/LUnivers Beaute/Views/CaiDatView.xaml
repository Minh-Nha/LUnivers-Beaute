<UserControl x:Class="LUnivers_Beaute.Views.CaiDatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Cài đặt Hệ thống" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="Cấu hình Email, Cloudinary và các tham số khác" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="16,12" Margin="0,0,8,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,3" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#E8956D"/>
                                        <Setter Property="Foreground" Value="#DE8A63"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#7A7A7A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#DE8A63"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: EMAIL -->
            <TabItem Header="📧 Email SMTP">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Cấu Hình Email (Gửi mã OTP)" FontSize="18" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,8"/>
                                <TextBlock Text="Dùng tài khoản Gmail của bạn để tự động gửi mã OTP khi nhân viên quên mật khẩu." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

                                <TextBlock Text="Địa chỉ Gmail gửi đi *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtSenderEmail" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="Mật khẩu ứng dụng (App Password) *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="txtAppPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,8"/>
                                <TextBlock Text="* Vui lòng vào Google Account &gt; Bảo mật &gt; Xác minh 2 bước &gt; Mật khẩu ứng dụng để tạo mã." FontSize="11" Foreground="#E74C3C" Margin="0,0,0,20"/>
                                
                                <Button Content="💾 LƯU CẤU HÌNH EMAIL" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Width="220" Click="BtnSave_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: CLOUDINARY -->
            <TabItem Header="☁️ Cloudinary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Cấu Hình Lưu Trữ Ảnh (Cloudinary)" FontSize="18" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,8"/>
                                <TextBlock Text="Thiết lập API key để upload hình ảnh sản phẩm lên máy chủ Cloudinary." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>
                                
                                <TextBlock Text="Cloud Name" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtCloudName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="API Key" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtApiKey" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="API Secret" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="txtApiSecret" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,20"/>
                                
                                <Button Content="💾 LƯU CẤU HÌNH CLOUDINARY" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Width="250" Click="BtnSave_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: VIETQR -->
            <TabItem Header="💳 Thanh Toán VietQR">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Cấu Hình Thanh Toán VietQR" FontSize="18" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,8"/>
                                <TextBlock Text="Thiết lập thông tin tài khoản ngân hàng để tự động tạo mã QR thanh toán cho khách hàng." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" TextWrapping="Wrap"/>
                                
                                <TextBlock Text="Ngân hàng nhận tiền *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cboBank" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16" SelectedValuePath="Bin">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Số tài khoản *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtAccountNumber" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="Tên chủ tài khoản *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtAccountName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20" CharacterCasing="Upper"/>
                                
                                <Button Content="💾 LƯU CẤU HÌNH VIETQR" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Width="220" Click="BtnSave_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- TAB 4: GEMINI AI -->
            <TabItem Header="🤖 Trợ lý AI (Gemini)">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Cấu Hình Trợ Lý AI" FontSize="18" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,8"/>
                                <TextBlock Text="Thiết lập API Key và chọn mô hình AI (Gemini) để hệ thống tự động phân tích và hỗ trợ người dùng." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" TextWrapping="Wrap"/>
                                
                                <TextBlock Text="API Key *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="txtGeminiApiKey" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="Mô hình (Model Name) *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cboGeminiModel" Style="{StaticResource ModernComboBox}" Margin="0,0,0,20">
                                    <ComboBoxItem Content="gemini-3.1-flash-lite (Siêu nhanh, rẻ)" Tag="gemini-3.1-flash-lite" IsSelected="True"/>
                                    <ComboBoxItem Content="gemini-2.0-flash (Cân bằng)" Tag="gemini-2.0-flash"/>
                                    <ComboBoxItem Content="gemini-1.5-pro (Mạnh mẽ, chậm hơn)" Tag="gemini-1.5-pro"/>
                                    <ComboBoxItem Content="gemini-flash-latest (Mới nhất)" Tag="gemini-flash-latest"/>
                                </ComboBox>
                                
                                <Button Content="💾 LƯU CẤU HÌNH AI" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Width="220" Click="BtnSave_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
