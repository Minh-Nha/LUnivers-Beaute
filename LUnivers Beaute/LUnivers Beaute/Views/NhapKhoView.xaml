<UserControl x:Class="LUnivers_Beaute.Views.NhapKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="1*" MinWidth="450"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Phiếu nhập List -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Nhập kho" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Quản lý phiếu nhập kho và chi tiết nhập" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnExportReport" Content="📥 Xuất báo cáo" Style="{StaticResource SecondaryButton}" Padding="14,10" Margin="0,0,10,0" Click="BtnExportReport_Click"/>
                    <Button Content="＋ Tạo phiếu nhập" Style="{StaticResource PrimaryButton}" Padding="14,10" Click="BtnTaoPhieuNhap_Click"/>
                </StackPanel>
            </Grid>
            
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" Tag="Tìm kiếm theo mã phiếu, người nhập..." Margin="0,0,10,0"/>
                    <DatePicker Grid.Column="1" Margin="0,0,10,0" FontSize="13" Style="{StaticResource ModernDatePicker}"/>
                    <DatePicker Grid.Column="2" Margin="0,0,10,0" FontSize="13" Style="{StaticResource ModernDatePicker}"/>
                    <Button Grid.Column="3" Content="🔍 Tìm kiếm" Style="{StaticResource PrimaryButton}" Padding="16,10"/>
                </Grid>
            </Border>
            
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📥 Danh sách phiếu nhập" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="20,20,0,16"/>
                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" x:Name="dgData" Style="{StaticResource ModernDataGrid}" 
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" 
                              CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ PHIẾU" Binding="{Binding MaPhieuNhap}" Width="100"/>
                            <DataGridTextColumn Header="CỬA HÀNG" Binding="{Binding TenCuaHang}" Width="130"/>
                            <DataGridTextColumn Header="NHÂN VIÊN" Binding="{Binding NhanVienNhap}" Width="130"/>
                            <DataGridTextColumn Header="NGÀY NHẬP" Binding="{Binding NgayNhap}" Width="140"/>
                            <DataGridTextColumn Header="TỔNG TIỀN" Binding="{Binding TongTienNhap, StringFormat={}{0:#,##0} đ}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,12">
                        <Button x:Name="btnPrevPage" Content="&lt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnPrevPage_Click"/>
                        <TextBlock x:Name="txtPageInfo" Text="Trang 1 / 1" VerticalAlignment="Center" Margin="16,0" FontWeight="SemiBold"/>
                        <Button x:Name="btnNextPage" Content="&gt;" Style="{StaticResource SecondaryButton}" Width="36" Height="36" Padding="0" Click="BtnNextPage_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT PANEL: Chi Tiết Nhập Kho -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20" x:Name="detailPanel" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✦ L'UNIVERS BEAUTÉ ✦" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentPeachBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="CHI TIẾT PHIẾU NHẬP" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Info -->
                <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Mã phiếu:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="lblMaPhieu" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Ngày nhập:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="lblNgayNhap" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Nhân viên:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="lblNhanVien" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Cửa hàng:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="lblCuaHang" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Items Grid -->
                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,16">
                    <DataGrid AutoGenerateColumns="False" x:Name="dgChiTiet" Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding TenSanPham}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="LÔ" Binding="{Binding SoLo}" Width="60"/>
                            <DataGridTextColumn Header="HSD" Binding="{Binding HanSuDung}" Width="80"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="40">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="THÀNH TIỀN" Binding="{Binding ThanhTien, StringFormat={}{0:#,##0} đ}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Summary -->
                <StackPanel Grid.Row="3" Margin="0,0,0,20">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,12"/>
                    <Grid>
                        <TextBlock Text="TỔNG TIỀN NHẬP:" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="lblTongTien" Text="0 đ" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="{StaticResource AccentPeachBrush}"/>
                    </Grid>
                </StackPanel>

                <!-- Actions -->
                <Button Grid.Row="4" Content="🖨️ IN PHIẾU NHẬP" Style="{StaticResource PrimaryButton}" Height="40" FontSize="13" Click="BtnPrint_Click"/>
            </Grid>
        </Border>

    </Grid>

        <!-- OVERLAY: Tạo Phiếu Nhập Mới -->
        <Grid x:Name="createPanel" Visibility="Collapsed">
            <Border Background="#88000000"/>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="1050" Height="700" 
                    Style="{StaticResource CardBorder}" Padding="28" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="TẠO PHIẾU NHẬP KHO MỚI" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" Click="BtnCloseCreate_Click"/>
                    </Grid>
                    
                    <!-- Content Split Layout -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <!-- Left: Form Thêm (330px) -->
                            <ColumnDefinition Width="330"/>
                            <!-- Spacing (24px) -->
                            <ColumnDefinition Width="24"/>
                            <!-- Right: Cart & Footer (*) -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- LEFT PANEL: Form Nhập Liệu -->
                        <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="THÔNG TIN SẢN PHẨM" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                                        
                                        <!-- Sản phẩm -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="Sản phẩm" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="cboSanPham" Style="{StaticResource ModernComboBox}" SelectedValuePath="MaSanPham" SelectionChanged="cboSanPham_SelectionChanged">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TenSanPham}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        
                                        <!-- Số lô -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="Số lô" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                            <Grid>
                                                <TextBox x:Name="txtSoLo" Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock Text="(Bỏ trống để tự tạo)" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0" Foreground="#AAA" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=txtSoLo}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <!-- Ngày SX & Hạn SD -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Ngày SX" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <DatePicker x:Name="dpNgaySX" Style="{StaticResource ModernDatePicker}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Hạn SD" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <DatePicker x:Name="dpHanSD" Style="{StaticResource ModernDatePicker}"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Số lượng & Giá nhập -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Số lượng" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <TextBox x:Name="txtSoLuong" Style="{StaticResource ModernTextBox}" Text="1"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Giá nhập (đ)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <TextBox x:Name="txtGiaNhap" Style="{StaticResource ModernTextBox}" TextChanged="TxtCurrency_TextChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Giá bán (Niêm yết) -->
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Giá bán niêm yết (đ)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="txtGiaNiemYet" Style="{StaticResource ModernTextBox}" TextChanged="TxtCurrency_TextChanged"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="＋ Thêm vào danh sách" Style="{StaticResource PrimaryButton}" Height="42" FontSize="13" Click="BtnAddImportItem_Click"/>
                                    <Button Grid.Column="2" Content="Tất cả (Test)" Height="42" FontSize="13" Padding="12,0" Background="#E9ECEF" BorderThickness="0" Foreground="#495057" Click="BtnAddAllItems_Click" ToolTip="Thêm tất cả sản phẩm vào danh sách để test"/>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <!-- RIGHT PANEL: Cart & Submit Footer -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Cart Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="DANH SÁCH SẢN PHẨM NHẬP" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            
                            <!-- Cart List -->
                            <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,0,0,20" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Table Header -->
                                    <Grid Background="#FAFAFA" Height="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SẢN PHẨM" Grid.Column="0" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                        <TextBlock Text="SỐ LÔ" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="HẠN SD" Grid.Column="2" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="SL" Grid.Column="3" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="GIÁ NHẬP" Grid.Column="4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                        <TextBlock Text="THÀNH TIỀN" Grid.Column="5" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                    </Grid>
                                    
                                    <!-- Scrollable Items List -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="dgImportCart">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Height="52">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2.2*"/>
                                                                <ColumnDefinition Width="1*"/>
                                                                <ColumnDefinition Width="1*"/>
                                                                <ColumnDefinition Width="0.8*"/>
                                                                <ColumnDefinition Width="1.4*"/>
                                                                <ColumnDefinition Width="1.4*"/>
                                                                <ColumnDefinition Width="44"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <TextBlock Text="{Binding TenSanPham}" Grid.Column="0" VerticalAlignment="Center" Margin="16,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SoLo}" Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding HanSD, StringFormat=dd/MM/yyyy}" Grid.Column="2" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            
                                                            <!-- Editable Quantity in Cart -->
                                                            <TextBox Text="{Binding SoLuong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="3" 
                                                                     Style="{StaticResource ModernTextBox}" Padding="6,6" FontSize="13" HorizontalContentAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                                                            
                                                            <!-- Editable Price in Cart -->
                                                            <TextBox Text="{Binding GiaNhap, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:#,##0}}" Grid.Column="4" 
                                                                     Style="{StaticResource ModernTextBox}" Padding="8,6" FontSize="13" HorizontalContentAlignment="Right" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                            
                                                            <TextBlock Text="{Binding ThanhTien, StringFormat={}{0:#,##0} đ}" Grid.Column="5" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                                            <Button Content="✕" Grid.Column="6" Style="{StaticResource IconButton}" Foreground="Red" Click="BtnRemoveImportItem_Click" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            
                            <!-- Submit Footer -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Cửa hàng" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cboCuaHang" Style="{StaticResource ModernComboBox}" Width="160" SelectedValuePath="MaCuaHang">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TenCuaHang}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <StackPanel>
                                        <TextBlock Text="Nhân viên" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cboNhanVien" Style="{StaticResource ModernComboBox}" Width="160" SelectedValuePath="MaNhanVien" SelectionChanged="cboNhanVien_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding HoTen}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                    <StackPanel Margin="0,0,0,12" HorizontalAlignment="Right">
                                        <TextBlock Text="TỔNG TIỀN NHẬP:" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="lblTongTienMoi" Text="0 đ" FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                    <Button Content="XÁC NHẬN NHẬP KHO" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" HorizontalAlignment="Stretch" Click="BtnXacNhanNhap_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>













