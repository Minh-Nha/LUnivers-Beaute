<Window x:Class="LUnivers_Beaute.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quên Mật Khẩu" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="16" Background="White" BorderBrush="#EDEDED" BorderThickness="1" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="Black"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid>
                <TextBlock Text="Khôi phục mật khẩu" FontSize="20" FontWeight="Bold" Foreground="#DE8A63" HorizontalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource IconButton}" Click="BtnClose_Click"/>
            </Grid>
            
            <StackPanel x:Name="pnlStep1" Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Nhập email tài khoản của bạn:" Foreground="#7A7A7A" Margin="0,0,0,10"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>
                <Button x:Name="btnSendOtp" Content="NHẬN MÃ OTP" Style="{StaticResource PrimaryButton}" Height="42" Click="BtnSendOtp_Click"/>
            </StackPanel>

            <StackPanel x:Name="pnlStep2" Grid.Row="1" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="Nhập mã OTP (6 số) gửi về email:" Foreground="#7A7A7A" Margin="0,0,0,10"/>
                <TextBox x:Name="txtOtp" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20" MaxLength="6" TextAlignment="Center" FontSize="18" FontWeight="Bold"/>
                <Button x:Name="btnVerifyOtp" Content="XÁC NHẬN MÃ" Style="{StaticResource PrimaryButton}" Height="42" Click="BtnVerifyOtp_Click"/>
            </StackPanel>

            <StackPanel x:Name="pnlStep3" Grid.Row="1" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="Mật khẩu mới:" Foreground="#7A7A7A" Margin="0,0,0,10"/>
                <PasswordBox x:Name="txtNewPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,10"/>
                <TextBlock Text="Xác nhận mật khẩu:" Foreground="#7A7A7A" Margin="0,0,0,10"/>
                <PasswordBox x:Name="txtConfirmPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,20"/>
                <Button x:Name="btnReset" Content="ĐỔI MẬT KHẨU" Style="{StaticResource PrimaryButton}" Height="42" Click="BtnReset_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
