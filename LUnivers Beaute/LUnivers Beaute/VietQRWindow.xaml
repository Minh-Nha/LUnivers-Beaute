<Window x:Class="LUnivers_Beaute.VietQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toán VietQR" Height="580" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="White" CornerRadius="16" BorderBrush="#EDEDED" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="20" Opacity="0.1"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Mã QR Thanh Toán" FontSize="20" FontWeight="Bold" Foreground="#2D2D2D" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            
            <Border Grid.Row="1" BorderBrush="#EDEDED" BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <TextBlock x:Name="txtStatus" Text="Đang tạo mã QR..." FontSize="14" Foreground="#7A7A7A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="imgQR" Stretch="Uniform"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="❌ HỦY BỎ" Style="{StaticResource SecondaryButton}" Height="46" FontSize="14" FontWeight="Bold" Click="BtnClose_Click"/>
                <Button Grid.Column="2" Content="✅ ĐÃ NHẬN TIỀN" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" FontWeight="Bold" Click="BtnConfirm_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
