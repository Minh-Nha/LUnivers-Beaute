<Window x:Class="LUnivers_Beaute.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="L'Univers Beauté — Đăng Nhập" 
        Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">
    
    <Border CornerRadius="16" Background="White" 
            BorderBrush="#EDEDED" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - BRANDING (warm cream bg) -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFF3EB" Offset="0"/>
                        <GradientStop Color="#FAE4D4" Offset="0.5"/>
                        <GradientStop Color="#F3D1BC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative circles -->
                    <Ellipse Width="250" Height="250" Opacity="0.15" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-60,-60,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#DE8A63" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="180" Height="180" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#C6936A" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Logo Icon -->
                        <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,24" HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DE8A63" Offset="0"/>
                                    <GradientStop Color="#C6936A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✦" FontSize="34" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Border>

                        <TextBlock Text="L'Univers" FontSize="34" FontWeight="Light" 
                                   Foreground="#3D3D3D" HorizontalAlignment="Center" FontFamily="Segoe UI Light"/>
                        <TextBlock Text="BEAUTÉ" FontSize="38" FontWeight="Bold" 
                                   Foreground="#DE8A63" HorizontalAlignment="Center" FontFamily="Segoe UI" Margin="0,-4,0,0"/>

                        <Border Height="2" Width="50" Margin="0,20,0,20" HorizontalAlignment="Center" CornerRadius="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#DE8A63" Offset="0"/>
                                    <GradientStop Color="#C6936A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="Hệ Thống Quản Lý Mỹ Phẩm" FontSize="13" Foreground="#7A7A7A" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock Text="Vẻ đẹp vũ trụ" FontSize="12" Foreground="#B0B0B0" HorizontalAlignment="Center" FontFamily="Segoe UI" Margin="0,4,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT PANEL - LOGIN FORM -->
            <Border Grid.Column="1" Padding="44" Background="White" CornerRadius="0,16,16,0">
                <Grid VerticalAlignment="Center">
                    <!-- Close Button -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Margin="0,-60,0,0" Style="{StaticResource IconButton}" Click="BtnClose_Click" FontSize="14"/>

                    <StackPanel>
                        <TextBlock Text="Chào mừng trở lại!" FontSize="24" FontWeight="Bold"
                                   Foreground="#2D2D2D" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock Text="Đăng nhập để tiếp tục quản lý" FontSize="13"
                                   Foreground="#7A7A7A" FontFamily="Segoe UI" Margin="0,0,0,32"/>

                        <TextBlock Text="TÊN ĐĂNG NHẬP" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,18"/>

                        <TextBlock Text="MẬT KHẨU" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,18"/>

                        <TextBlock Text="CỬA HÀNG" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbCuaHang" Style="{StaticResource ModernComboBox}" Margin="0,0,0,28">
                            <ComboBoxItem Content="Chi nhánh Quận 1" IsSelected="True"/>
                            <ComboBoxItem Content="Chi nhánh Quận 3"/>
                            <ComboBoxItem Content="Chi nhánh Quận 7"/>
                        </ComboBox>

                        <Button Content="ĐĂNG NHẬP" Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" Click="BtnLogin_Click"/>

                        <TextBlock Text="Quên mật khẩu?" FontSize="12" Margin="0,18,0,0"
                                   Foreground="#DE8A63" HorizontalAlignment="Center" Cursor="Hand" FontFamily="Segoe UI"/>

                        <TextBlock Text="v1.0.0 — L'Univers Beauté © 2026" FontSize="10" Margin="0,36,0,0"
                                   Foreground="#B0B0B0" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

